# ============================================================
# Pop Cube Wallet — Environment Configuration
# Copy this file to .env and adjust the values for your setup.
# ============================================================

# PostgreSQL connection
DB_HOST=localhost        # Database host (use 'postgres' inside Docker network)
DB_PORT=5432             # Database port
DB_NAME=pop_cube_wallet  # Database name (must match docker-compose)
DB_USER=wallet_user      # Database username
DB_PASS=wallet_pass      # Database password

# Application server
SERVER_PORT=8080         # HTTP port the Spring Boot app listens on
